        "# Ejemplo de cómo se haría con LabelEncoder\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "\n",
        "# Inicializar el LabelEncoder\n",
        "# Creamos una instancia del codificador.\n",
        "le = LabelEncoder()\n",
